{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "uv venv .venv && uv pip install --python .venv/bin/python . 'mkdocstrings[python]>=0.26.1'",
  "buildCommand": ".venv/bin/mkdocs build --strict --config-file pages/mkdocs.yml --site-dir public",
  "outputDirectory": "pages/public"
}
